{
  "name": "minio-upload-service",
  "version": "1.0.0",
  "description": "Secure file upload microservice using MinIO presigned URLs + Hasura",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp -r src/dashboard dist/dashboard",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.18.2",
    "minio": "^7.1.3",
    "uuid": "^9.0.0",
    "dotenv": "^16.3.1",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/uuid": "^9.0.7",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2",
    "ts-node-dev": "^2.0.0",
    "@types/pg": "^8.10.9"
  }
}
