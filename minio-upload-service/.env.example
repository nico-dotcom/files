# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# Master key — usada SOLO para gestionar API keys vía dashboard y /admin/*
# Nunca enviar al frontend.
# MÍNIMO 32 caracteres. Generá una con:  openssl rand -hex 32
MASTER_API_KEY=REEMPLAZAR-con-openssl-rand-hex-32-resultado

# ─── MinIO ────────────────────────────────────────────────────────────────────
# Hostname/IP del servidor MinIO (sin protocolo ni puerto)
S3_ENDPOINT=localhost

# Puerto de la API de MinIO (default 9000)
S3_PORT=9000

# Poner "true" solo si MinIO está detrás de HTTPS/TLS
S3_USE_SSL=false

# Usar una access key dedicada — nunca usar las credenciales root en producción
S3_ACCESS_KEY=your-access-key-here
# MÍNIMO 16 caracteres.
S3_SECRET_KEY=your-secret-key-minimum-16-chars

# Bucket que debe existir previamente en MinIO
S3_BUCKET=files

# URL pública de MinIO expuesta vía Cloudflare Tunnel.
# Las presigned PUT/GET URLs enviadas al frontend usarán este hostname.
# Debe coincidir con el hostname del Cloudflare Tunnel que apunta al puerto 9000 de MinIO.
# Dejar vacío para desarrollo local (las URLs usarán localhost:9000).
S3_PUBLIC_URL=https://storage.yourdomain.com

# Cuánto tiempo son válidas las presigned URLs (segundos). Default: 900 (15 min)
PRESIGNED_URL_EXPIRY_SECONDS=900

# Tamaño máximo de subida en bytes. Default: 104857600 (100 MB)
MAX_FILE_SIZE_BYTES=104857600

# ─── Hasura ───────────────────────────────────────────────────────────────────
# URL completa del endpoint GraphQL de Hasura
HASURA_GRAPHQL_URL=http://localhost:8080/v1/graphql

# Admin secret — NUNCA exponer al frontend. MÍNIMO 16 caracteres.
HASURA_ADMIN_SECRET=your-hasura-admin-secret-min-16-chars

# Conexión a la base de datos (solo necesaria si levantás Hasura con docker-compose)
# Formato: postgres://user:password@host:5432/dbname
HASURA_GRAPHQL_DATABASE_URL=postgres://postgres:your-postgres-password@your-db-host:5432/appdb
