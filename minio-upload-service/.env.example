# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# API key that clients must send as:  Authorization: Bearer <API_KEY>
# Generate with:  openssl rand -hex 32
API_KEY=change-me-use-openssl-rand-hex-32

# ─── MinIO ────────────────────────────────────────────────────────────────────
# Hostname/IP of your MinIO server (no protocol prefix, no port)
S3_ENDPOINT=localhost

# MinIO API port (default 9000)
S3_PORT=9000

# Set to "true" only if MinIO is behind HTTPS/TLS
S3_USE_SSL=false

# Use a dedicated access key — never use root credentials in production
S3_ACCESS_KEY=your-access-key-here
S3_SECRET_KEY=your-secret-key-here

# The bucket that must already exist in MinIO
S3_BUCKET=files

# Public MinIO URL exposed via Cloudflare Tunnel.
# Presigned PUT/GET URLs sent to the frontend will use this hostname.
# Must match the Cloudflare Tunnel hostname that forwards to MinIO port 9000.
# Leave empty for local-only development (presigned URLs will use localhost:9000).
S3_PUBLIC_URL=https://storage.yourdomain.com

# How long presigned URLs stay valid (seconds). Default: 900 (15 minutes)
PRESIGNED_URL_EXPIRY_SECONDS=900

# Maximum allowed upload size in bytes. Default: 104857600 (100 MB)
MAX_FILE_SIZE_BYTES=104857600

# ─── Hasura ───────────────────────────────────────────────────────────────────
# Full URL to Hasura's GraphQL endpoint
HASURA_GRAPHQL_URL=http://localhost:8080/v1/graphql

# Admin secret — NEVER expose this to the frontend
HASURA_ADMIN_SECRET=your-hasura-admin-secret-here
